# Registry configuration
registry=https://registry.npmjs.org/

# Security settings
audit=true
audit-level=moderate

# Save exact versions
save-exact=false

# Installation behavior
fund=true
optional=true

# Cache configuration
cache=${APPDATA}\npm-cache

# Logging
loglevel=notice

# Progress
progress=true

# Engine strictness
engine-strict=true

# Package lock settings
package-lock=true

# Script shell (Windows)
script-shell="C:\\Program Files\\PowerShell\\7\\pwsh.exe"

# Auto-install peer dependencies
auto-install-peers=true

# Prefer offline cache
prefer-offline=true

# Timeout settings
fetch-timeout=60000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# Maximum number of retries
fetch-retries=3
